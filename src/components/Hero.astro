---
import { t, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
  name: string;
  title: string;
  company: string;
  tagline: string;
}

const { locale, name, title, company, tagline } = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center justify-center pt-16">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-sky-500/10 dark:from-sky-500/5 via-transparent to-transparent pointer-events-none" />
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[80vw] sm:w-[600px] h-[80vw] sm:h-[600px] bg-sky-500/10 dark:bg-sky-500/5 rounded-full blur-3xl pointer-events-none" />

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <!-- Avatar -->
    <div class="w-24 h-24 sm:w-36 sm:h-36 mx-auto mb-8 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 p-0.5">
      <div class="w-full h-full rounded-full" style="background: url('https://0.gravatar.com/avatar/aac8b2630027d2debbeff075e36ec179037d106e578e1ee3c46db480a720a986?size=512') 45% 30% / 200% no-repeat;" role="img" aria-label="Johnson"></div>
    </div>

    <!-- Name & Title -->
    <p class="text-sky-400 text-sm font-medium tracking-wider uppercase mb-3">
      {t(locale, 'hero.greeting')}
    </p>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">
      {name}
    </h1>
    <p class="text-lg sm:text-xl text-slate-500 dark:text-slate-400 mb-3">
      {title} @ {company}
    </p>
    <p class="text-base sm:text-lg text-slate-400 dark:text-slate-500 max-w-2xl mx-auto mb-10" set:html={tagline} />

    <!-- Social Links -->
    <div class="flex items-center justify-center gap-3 sm:gap-4 mb-12">
      <a href="https://github.com/johnsonlee" target="_blank" rel="noopener"
        class="p-2.5 sm:p-3 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-white/10 hover:border-slate-300 dark:hover:border-white/20 transition-all"
        aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="mailto:g.johnsonlee@gmail.com"
        class="p-2.5 sm:p-3 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-white/10 hover:border-slate-300 dark:hover:border-white/20 transition-all"
        aria-label="Email">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
      <a href="https://johnsonlee.io" target="_blank" rel="noopener"
        class="p-2.5 sm:p-3 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-white/10 hover:border-slate-300 dark:hover:border-white/20 transition-all"
        aria-label="Blog">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      </a>
      <a href="https://medium.com/@johnson.lee" target="_blank" rel="noopener"
        class="p-2.5 sm:p-3 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-white/10 hover:border-slate-300 dark:hover:border-white/20 transition-all"
        aria-label="Medium">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <a href="#about" class="inline-flex flex-col items-center text-slate-400 dark:text-slate-500 hover:text-sky-400 transition-colors">
      <span class="text-xs mb-2">{t(locale, 'hero.cta')}</span>
      <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </a>
  </div>
</section>
