---
interface Props {
  name: string;
  url: string;
  description: string;
  stars?: string;
}

const { name, url, description, stars } = Astro.props;
---

<a href={url} target="_blank" rel="noopener" class="glass-card block group">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-slate-900 dark:text-white font-semibold group-hover:text-sky-400 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        {name}
      </h3>
      <p class="text-slate-400 text-sm mt-1">{description}</p>
    </div>
    {stars && (
      <span class="flex items-center gap-1 text-amber-400 text-sm whitespace-nowrap">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {stars}
      </span>
    )}
  </div>
</a>
