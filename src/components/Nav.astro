---
import { t, locales, type Locale } from '@/i18n';

const navItems = [
  { key: 'about', href: '#about' },
  { key: 'ai', href: '#ai' },
  { key: 'opensource', href: '#opensource' },
  { key: 'career', href: '#career' },
  { key: 'contact', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-slate-200 dark:border-white/5">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="hover:opacity-80 transition-opacity">
      <img src="/logo.svg" alt=">_" class="h-8 w-8" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <>
          {locales.map(locale => (
            <a href={item.href} data-lang={locale} class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors hidden">
              {t(locale, `nav.${item.key}`)}
            </a>
          ))}
        </>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <button id="theme-toggle" class="p-2 rounded-lg border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-white/30 transition-all" aria-label="Toggle theme">
        <svg id="theme-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg id="theme-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>

      <button id="lang-switch" class="text-sm px-3 py-1.5 rounded-lg border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-white/30 transition-all">
        <span data-lang="zh" class="hidden">{t('zh', 'lang.switch')}</span>
        <span data-lang="en" class="hidden">{t('en', 'lang.switch')}</span>
      </button>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-toggle" class="md:hidden p-2 rounded-lg border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all" aria-label="Menu">
        <svg id="menu-open-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="menu-close-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 dark:border-white/5 bg-white/95 dark:bg-slate-950/95 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-4 py-4 flex flex-col gap-3">
      {navItems.map(item => (
        <>
          {locales.map(locale => (
            <a href={item.href} data-lang={locale} class="mobile-nav-link text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors py-2 hidden">
              {t(locale, `nav.${item.key}`)}
            </a>
          ))}
        </>
      ))}
    </div>
  </div>
</nav>
