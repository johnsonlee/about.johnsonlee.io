---
import { t, locales, type Locale } from '@/i18n';
---

<!-- Floating Share Bar -->
<div class="hidden sm:flex fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-40 flex-col gap-2">
  <button data-share="wechat" class="p-2.5 sm:p-3 rounded-full bg-white/90 dark:bg-slate-800/90 backdrop-blur border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-green-400 hover:border-green-400/30 transition-all shadow-lg" aria-label="WeChat">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05a6.127 6.127 0 01-.253-1.736c0-3.74 3.568-6.768 7.969-6.768.267 0 .527.022.789.04C17.085 4.692 13.215 2.188 8.691 2.188zm-2.35 4.472c.593 0 1.074.478 1.074 1.07s-.481 1.072-1.074 1.072a1.073 1.073 0 01-1.073-1.072c0-.592.48-1.07 1.073-1.07zm4.71 0c.593 0 1.073.478 1.073 1.07s-.48 1.072-1.073 1.072a1.073 1.073 0 01-1.073-1.072c0-.592.48-1.07 1.073-1.07zM16.218 8.87c-3.867 0-7.003 2.676-7.003 5.98 0 3.303 3.136 5.98 7.003 5.98a8.856 8.856 0 002.423-.34.725.725 0 01.588.082l1.573.92a.268.268 0 00.139.044.242.242 0 00.238-.244c0-.06-.023-.118-.039-.176l-.326-1.229a.488.488 0 01.176-.548C22.772 18.283 24 16.416 24 14.85c0-3.304-3.136-5.98-7.003-5.98h.22zm-2.79 3.268c.506 0 .917.41.917.915s-.41.914-.916.914a.916.916 0 01-.917-.914c0-.505.411-.915.917-.915zm4.357 0c.506 0 .917.41.917.915s-.41.914-.917.914a.916.916 0 01-.916-.914c0-.505.41-.915.916-.915z"/></svg>
  </button>
  <a href="https://github.com/johnsonlee" target="_blank" rel="noopener" title="GitHub" class="p-2.5 sm:p-3 rounded-full bg-white/90 dark:bg-slate-800/90 backdrop-blur border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-white hover:border-white/30 transition-all shadow-lg" aria-label="GitHub">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
  </a>
  <button data-share="copy" class="p-2.5 sm:p-3 rounded-full bg-white/90 dark:bg-slate-800/90 backdrop-blur border border-slate-200 dark:border-white/10 text-slate-500 dark:text-slate-400 hover:text-amber-400 hover:border-amber-400/30 transition-all shadow-lg" aria-label="Copy Link">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
  </button>
</div>

<!-- WeChat QR Modal -->
<div id="wechat-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-2xl p-8 max-w-sm mx-4 text-center">
    {locales.map(locale => (
      <h3 data-lang={locale} class="text-lg font-semibold text-slate-900 dark:text-white mb-4 hidden">{t(locale, 'share.wechat')}</h3>
    ))}
    <div class="bg-white rounded-xl p-4 mb-4 inline-block">
      <img id="wechat-qr-img" alt="QR Code" class="w-48 h-48" />
    </div>
    {locales.map(locale => (
      <p data-lang={locale} class="text-slate-400 text-sm mb-4 hidden">
        {locale === 'zh' ? '\u6253\u5F00\u5FAE\u4FE1\u626B\u4E00\u626B' : 'Scan with WeChat'}
      </p>
    ))}
    <button id="wechat-modal-close" class="px-4 py-2 rounded-lg bg-slate-100 dark:bg-white/10 text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-white/20 transition-colors text-sm">
      <span data-lang="zh" class="hidden">{'\u5173\u95ED'}</span>
      <span data-lang="en" class="hidden">Close</span>
    </button>
  </div>
</div>
