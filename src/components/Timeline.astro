---
interface TimelineItem {
  company: string;
  role: string | string[];
  description: string;
  highlight?: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<div class="relative">
  <!-- Timeline line -->
  <div class="absolute top-0 bottom-0 w-px bg-gradient-to-b from-sky-500 via-sky-500/50 to-transparent" style="left: 21px;" />

  <div class="space-y-8">
    {items.map((item, i) => {
      const opacity = 1 - (i / items.length) * 0.6;
      return (
        <div class="relative pl-14" style={`opacity: ${opacity};`}>
          <!-- Dot -->
          <div class={`absolute w-3 h-3 rounded-full border-2 top-7 ${i === 0 ? 'bg-sky-500 border-sky-400' : 'bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600'}`} style="left: 16px;" />

          <div class="glass-card">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">{item.company}</h3>
              <div class="flex flex-wrap gap-1.5">
                {(Array.isArray(item.role) ? item.role : [item.role]).map(r => (
                  <span class="tag">{r}</span>
                ))}
              </div>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed">{item.description}</p>
            {item.highlight && (
              <p class="mt-3 text-sm text-sky-400/80 italic">"{item.highlight}"</p>
            )}
          </div>
        </div>
      );
    })}
  </div>
</div>
